{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExtractedDocument",
  "type": "object",
  "required": [
    "document_id",
    "language",
    "status",
    "chunks",
    "entities",
    "relations",
    "numeric_values",
    "facts"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "ru",
        "en",
        "mixed"
      ]
    },
    "status": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "chunks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chunk"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "numeric_values": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/numeric_value"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fact"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "chunk": {
      "type": "object",
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "page": {
          "type": [
            "integer",
            "null"
          ]
        },
        "text": {
          "type": "string"
        },
        "embedding_text": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object",
      "required": [
        "id",
        "type",
        "name",
        "canonical_name",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "canonical_name": {
          "type": "string"
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_chunk_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "page": {
          "type": [
            "integer",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "relation": {
      "type": "object",
      "required": [
        "id",
        "type",
        "source_entity_id",
        "target_entity_id",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "source_entity_id": {
          "type": "string"
        },
        "target_entity_id": {
          "type": "string"
        },
        "source_chunk_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "numeric_value": {
      "type": "object",
      "required": [
        "id",
        "parameter",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "parameter": {
          "type": "string"
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "number",
            "null"
          ]
        },
        "value_min": {
          "type": [
            "number",
            "null"
          ]
        },
        "value_max": {
          "type": [
            "number",
            "null"
          ]
        },
        "comparator": {
          "type": [
            "string",
            "null"
          ]
        },
        "unit_original": {
          "type": [
            "string",
            "null"
          ]
        },
        "unit_normalized": {
          "type": [
            "string",
            "null"
          ]
        },
        "context": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_chunk_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "page": {
          "type": [
            "integer",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "fact": {
      "type": "object",
      "required": [
        "id",
        "claim_text",
        "fact_type",
        "source",
        "confidence",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "claim_text": {
          "type": "string"
        },
        "fact_type": {
          "type": "string"
        },
        "subject_entity_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "object_entity_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "numeric_value_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "$ref": "#/$defs/fact_source"
        },
        "geo_scope": {
          "type": "string",
          "enum": [
            "domestic",
            "foreign",
            "all",
            "unknown"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "year": {
          "type": [
            "integer",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "verification_level": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "document_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "filename": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_type": {
          "type": "string"
        },
        "access_level": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential"
          ]
        },
        "year": {
          "type": [
            "integer",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        },
        "organization": {
          "type": [
            "string",
            "null"
          ]
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "fact_source": {
      "type": "object",
      "required": [
        "document_id"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "chunk_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "page": {
          "type": [
            "integer",
            "null"
          ]
        },
        "quote": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}