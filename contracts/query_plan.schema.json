{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueryPlan",
  "type": "object",
  "required": [
    "intent",
    "materials",
    "processes",
    "geo_scope",
    "confidence_min",
    "numeric_constraints"
  ],
  "properties": {
    "intent": {
      "type": "string"
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "processes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "properties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "geo_scope": {
      "type": "string",
      "enum": [
        "domestic",
        "foreign",
        "all",
        "unknown"
      ]
    },
    "countries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "year_from": {
      "type": [
        "integer",
        "null"
      ]
    },
    "year_to": {
      "type": [
        "integer",
        "null"
      ]
    },
    "confidence_min": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "numeric_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "parameter",
          "operator"
        ],
        "properties": {
          "parameter": {
            "type": "string"
          },
          "operator": {
            "type": "string",
            "enum": [
              "between",
              "<",
              "<=",
              ">",
              ">=",
              "="
            ]
          },
          "value": {
            "type": [
              "number",
              "null"
            ]
          },
          "value_min": {
            "type": [
              "number",
              "null"
            ]
          },
          "value_max": {
            "type": [
              "number",
              "null"
            ]
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "comparison_mode": {
      "type": "boolean"
    },
    "group_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "auto_extracted",
        "source_supported",
        "expert_verified",
        "contradicted",
        "deprecated",
        null
      ]
    },
    "fact_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "verification_level": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_type": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
